{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenixrooivalk.com/schemas/products.json",
  "title": "Phoenix Rooivalk Product Catalog",
  "description": "Schema for validating the exported product catalog",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["sku", "name", "line", "category"],
    "properties": {
      "sku": {
        "type": "string",
        "pattern": "^[A-Z]{2,4}-[A-Z0-9-]+$",
        "description": "Unique product SKU (e.g., SW-NANO-01)"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Product display name"
      },
      "line": {
        "type": "string",
        "enum": ["SkyWatch", "NetSentry", "NetSnare", "SkySnare", "AeroNet", "C2C", "RKV", "Mesh"],
        "description": "Product line"
      },
      "category": {
        "type": "string",
        "enum": ["detection", "response", "c2", "mesh", "integration", "accessory"],
        "description": "Product category"
      },
      "targetMarket": {
        "type": "string",
        "enum": ["residential", "commercial", "enterprise", "military", "government"],
        "description": "Primary target market"
      },
      "priceRange": {
        "type": "string",
        "description": "Human-readable price range (e.g., '$500-$1000')"
      },
      "priceMin": {
        "type": "number",
        "minimum": 0,
        "description": "Minimum price in USD"
      },
      "priceMax": {
        "type": "number",
        "minimum": 0,
        "description": "Maximum price in USD"
      },
      "bomTotal": {
        "type": "number",
        "minimum": 0,
        "description": "Bill of materials total cost"
      },
      "confidence": {
        "type": "string",
        "enum": ["high", "medium", "low"],
        "description": "Pricing confidence level"
      },
      "lastUpdated": {
        "type": "string",
        "format": "date",
        "description": "Last update date (YYYY-MM-DD)"
      },
      "specs": {
        "type": "object",
        "description": "Product-specific specifications",
        "additionalProperties": true
      },
      "features": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of product features"
      },
      "status": {
        "type": "string",
        "enum": ["concept", "prototype", "production", "deprecated"],
        "description": "Product development status"
      }
    }
  }
}
